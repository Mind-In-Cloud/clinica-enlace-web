amends "package://github.com/jdx/hk/releases/download/v1.38.0/hk@1.38.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.38.0/hk@1.38.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    // Add linters here. Examples:
    // ["prettier"] = Builtins.prettier
    // ["eslint"] = Builtins.eslint
    // ["ruff"] = Builtins.ruff
    ["biome"] = Builtins.biome

    // Or define custom steps:
    // ["custom"] {
    //     glob = "**/*.py"
    //     check = "mypy {{ files }}"
    // }

    ["astro"] {
        glob = "**/*.astro"
        check = "pnpm astro check {{ files }}"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
