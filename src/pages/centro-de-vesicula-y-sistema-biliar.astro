---
import BaseLayout from '@layouts/base.astro';

import Map from '@components/Map.astro';

import seoImage from '@images/colab.jpg';
import vesiculaYellow from '@icons/vesicula_amarillo.svg?raw';
import cirujanosImg from '@images/cirujanos.jpg'

import ContactPanel from '@components/ContactPanel.astro';
import MediaPanel from '@components/MediaPanel.astro';
import GreatList from '@components/GreatList.astro';
import DoctorCabinet from '@components/DoctorCabinet';
import SidePanel from '@components/SidePanel.astro';

import { getCollection } from 'astro:content';

const allDoctors = await getCollection("medicos", ({data}) => {
  if (!Array.isArray(data.centros)) return false;
  return data.centros.some(c =>
    typeof c === 'object' &&
    (c.center === 'hepatobiliar')
  );
});

const seo = {
  title: 'Centro de Vesícula y Sistema Biliar',
  description: 'Centro de Vesícula y Sistema Biliar, diagnóstico y tratamiento avanzado de enfermedades biliares en clínica de corta estancia.',
  image: seoImage,
}
---
<BaseLayout {seo} breadcrumbs={{title:"Ir a Centros de Especialidad", url:'/centros-de-especialidad'}} isIframe={true}>
  <iframe
    src="https://vesiculaysistemabiliar.webflow.io/"
    title="Centro de Vesícula y Sistema Biliar" style="width:100%; height:100vh; border:none;"
  ></iframe>
</BaseLayout>
