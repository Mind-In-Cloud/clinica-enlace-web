---
import Link from "@elements/Link.astro";

import classy from "@utils/classy"

const {
  title,
  url,
  links = [],
  blog = false,
  class: className = '',
} = Astro.props;

const breadcrumbsClasses = classy([
  "k-breadcrumbs",
  "k-section",
  "m-0",
  className
]);
---
<div {...breadcrumbsClasses}>
  { links.length > 0 ? links.map(( link: { url: string; title: string; active : boolean ;} , index : number )  => {
    const {
      url,
      title
    } = link;
    return (
      <Link
        nav
        navChevron = { index !== 0 }
        {blog}
        {url}
        class = { index === 1 ? '' : 'hidden md:inline'  }
      >
        {title}
      </Link>
    )
  }) :
    <Link
      nav
      {url}
    >
      {title}
    </Link>
  }
</div>
