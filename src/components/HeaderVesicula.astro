---
import Logo from "@header/vesicula/Logo.astro"
import Menu from '@header/vesicula/HeaderMenu.astro';

let linkProps : { [key: string]: string } = {
  class : "col-span-5 lg:col-span-1",
  href:"/centro-de-vesicula-y-sistema-biliar"
}

if ( Astro.url.pathname === '/' ){
  linkProps['aria-current']="page"
}
---
<header class="grid grid-cols-6 px-8 gap-x-4 lg:px-16 py-6 sticky top-0 bg-white z-30">
  <a {...linkProps} aria-label="Enlace a página de centro de vesícula y sistema biliar">
    <Logo/>
  </a>
  <Menu/>
</header>
